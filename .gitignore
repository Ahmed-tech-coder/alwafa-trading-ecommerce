# ==============================================================================
# AL WAFA TRADING - GitHub .gitignore Configuration
# Optimized for React (Vite) + Tailwind CSS + Vercel Deployment workflows.
# ==============================================================================

# 📦 Dependencies & Packages
# ------------------------------------------------------------------------------
node_modules/
/jspm_packages/
/web_modules/
.pnp/
.pnp.js

# 🚀 Production Build Outputs
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
bin/
obj/
*.local

# 🔒 Secrets, Credentials & Local Environment Files
# ------------------------------------------------------------------------------
# NEVER commit raw keys, credentials, or environment secrets to GitHub.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.pub
*.cert
*.pfx
credentials.json

# 📊 Logs, Debugging & Diagnostic Diagnostics
# ------------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# 🛠️ Editor & IDE Settings (VS Code, JetBrains, Visual Studio)
# ------------------------------------------------------------------------------
# Ignore workspaces and editor preferences, but allow team extensions mapping.
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.user
*.userosscache
*.sln.docstates

# 💻 System & OS-Specific Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
db.files
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# 🧪 Testing & Code Coverage Outputs
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
.jest/
*.lcov

# ⚡ Bundler, Transpiler, and Runtime Caches
# ------------------------------------------------------------------------------
.eslintcache
.stylelintcache
.parcel-cache
.turbo/
.vite/
.rollup.cache/

# ☁️ Cloud Providers & Deployment Platforms
# ------------------------------------------------------------------------------
# Vercel deployment credentials and linking directories
.vercel/
